# iotedge-echosounder — Standalone Mode Configuration
#
# Copy this file to .env and adjust for your local environment.
# Only needed when running standalone.py (NOT the Azure IoT Edge module).

# Storage backend — must be "local" for standalone
STORAGE_BACKEND=local

# Base path for all output data (echodata, echograms, processed, reports)
OUTPUT_BASE_PATH=./output

# Sonar model: EK80, EK60, AZFP, AD2CP
SONAR_MODEL=EK80

# Waveform mode: CW (continuous wave) or BB (broadband)
WAVEFORM_MODE=CW

# Encode mode: power or complex
ENCODE_MODE=power

# Transducer depth offset in metres
DEPTH_OFFSET=0.0

# Survey / platform metadata
SURVEY_ID=
SURVEY_NAME=
PLATFORM_TYPE=
PLATFORM_NAME=
PLATFORM_CODE_ICES=

# GPU acceleration (disabled by default on macOS / non-CUDA systems)
USE_GPU=false

# Pipeline toggles
DENOISE_ENABLED=true
MVBS_ENABLED=true
NASC_ENABLED=false
SEABED_ENABLED=false
PLOT_ECHOGRAM=true

# Denoise methods (comma-separated): background,transient,impulse,attenuation
DENOISE_METHODS=background,transient,impulse,attenuation

# MVBS bins
MVBS_RANGE_BIN=0.5
MVBS_PING_TIME_BIN=10s

# NASC bins
NASC_RANGE_BIN=10
NASC_DIST_BIN=0.5

# Seabed detection
SEABED_METHOD=ariza
SEABED_MAX_RANGE=1000.0

# Container names (used as subfolder names in local mode)
CONVERTED_CONTAINER_NAME=echodata
ECHOGRAM_CONTAINER_NAME=echograms
PROCESSED_CONTAINER_NAME=processed

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
